{
  "name": "symphony-ts",
  "version": "0.1.0",
  "description": "Symphony - TypeScript implementation. Orchestrates coding agents for project work via Linear.",
  "main": "dist/cli.js",
  "bin": {
    "symphony": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
